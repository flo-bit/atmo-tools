{
	"name": "search-bluesky-likes",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"env:generate-key": "npx tsx src/lib/atproto/scripts/generate-key.ts",
		"env:generate-secret": "npx tsx src/lib/atproto/scripts/generate-secret.ts",
		"env:setup-dev": "npx tsx src/lib/atproto/scripts/setup-dev.ts",
		"tunnel": "npx tsx src/lib/atproto/scripts/tunnel.ts"
	},
	"devDependencies": {
		"@atcute/atproto": "^3.1.10",
		"@atcute/bluesky": "^3.2.19",
		"@atcute/client": "^4.2.1",
		"@atcute/identity-resolver": "^1.2.2",
		"@atcute/lexicons": "^1.2.9",
		"@atcute/oauth-node-client": "^1.1.0",
		"@atcute/tid": "^1.1.2",
		"@cloudflare/workers-types": "^4.20260301.1",
		"@eslint/compat": "^2.0.2",
		"@eslint/js": "^10.0.1",
		"@sveltejs/adapter-cloudflare": "^7.2.8",
		"@sveltejs/kit": "^2.53.4",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/vite": "^4.2.1",
		"eslint": "^10.0.2",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.15.0",
		"globals": "^17.4.0",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.0",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"svelte": "^5.53.6",
		"svelte-check": "^4.4.4",
		"tailwindcss": "^4.2.1",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.56.1",
		"vite": "^7.3.1"
	},
	"dependencies": {
		"@foxui/core": "^0.5.1",
		"@foxui/social": "^0.5.1",
		"flexsearch": "^0.8.212",
		"valibot": "^1.2.0"
	},
	"license": "MIT",
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild",
			"workerd",
			"@atcute/time-ms",
			"sharp"
		]
	}
}